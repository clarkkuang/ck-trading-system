# Financial Modeling Prep API Key (free tier: https://financialmodelingprep.com/)
FMP_API_KEY=

# FRED API Key (free: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# OpenRouter API Key (optional; free at https://openrouter.ai/keys)
# Enables daily token rankings for the AI model share monitor.
# Without it the monitor still collects pricing + npm/PyPI downloads.
OPENROUTER_API_KEY=

# Notification settings (Apprise URLs)
# Telegram: tgram://bot_token/chat_id
# Email: mailto://user:pass@gmail.com
NOTIFICATION_URLS=

# Data directory (default: ./data)
DATA_DIR=./data
